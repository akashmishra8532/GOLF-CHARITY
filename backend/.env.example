# ==========================================
# Golf Charity Platform - Backend Environment
# ==========================================

# Server Configuration
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# Database (MongoDB) - REQUIRED
# ==========================================
# Option 1: MongoDB Atlas (Cloud) - RECOMMENDED for production
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority"

# Option 2: Local MongoDB (Development only)
# MONGODB_URI="mongodb://localhost:27017/golf-charity"

# ==========================================
# Supabase (Optional Alternative)
# ==========================================
SUPABASE_URL="https://<project-id>.supabase.co"
SUPABASE_ANON_KEY="<supabase-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-key>"

# ==========================================
# Authentication - REQUIRED
# ==========================================
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ==========================================
# Stripe Payments - REQUIRED for subscriptions
# ==========================================
STRIPE_SECRET_KEY="sk_test_..."  # Use sk_live_ for production
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY_ID="price_..."
STRIPE_PRICE_YEARLY_ID="price_..."
STRIPE_SUCCESS_URL="http://localhost:5173/subscription?success=1"
STRIPE_CANCEL_URL="http://localhost:5173/subscription?canceled=1"

# ==========================================
# Email Configuration (Optional)
# ==========================================
# For Gmail SMTP:
# 1. Enable 2-Factor Authentication
# 2. Generate App Password at https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@golfcharity.com"

# ==========================================
# File Upload Configuration
# ==========================================
WINNER_PROOF_UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880  # 5MB in bytes

# ==========================================
# Pricing Configuration (in cents)
# ==========================================
PRICE_MONTHLY_AMOUNT_CENTS=2999    # $29.99
PRICE_YEARLY_AMOUNT_CENTS=29999  # $299.99

# ==========================================
# Admin Bootstrap (First-run admin creation)
# ==========================================
ADMIN_BOOTSTRAP_EMAIL="admin@golfcharity.com"
ADMIN_BOOTSTRAP_PASSWORD="change-me-to-strong-password-123!"

# ==========================================
# Security & Monitoring (Optional)
# ==========================================
# RATE_LIMIT_WINDOW_MS=900000        # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=100
# BCRYPT_SALT_ROUNDS=12
