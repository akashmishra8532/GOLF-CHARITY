{
  "version": 2,
  "buildCommand": "cd backend && npm run build",
  "outputDirectory": "backend/dist",
  "installCommand": "cd backend && npm install",
  "builds": [
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/src/server.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
